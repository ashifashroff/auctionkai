# AuctionKai Database Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

DB_HOST=localhost
DB_NAME=auctionkai
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# App URL (optional, auto-detected if empty)
APP_URL=

# Secret key for encrypting sensitive settings (SMTP passwords, etc.)
# Generate with: openssl rand -hex 32
APP_SECRET_KEY=your-random-64-char-secret-key-here
